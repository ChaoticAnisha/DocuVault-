# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
.next/

# Logs — root-level volume and any nested log dirs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
backend/logs/*
!backend/logs/.gitkeep

# Environment variables — never commit real secrets
.env
.env.local
.env.production
.env.*.local
backend/.env
frontend/.env

# Encrypted user uploads — root-level docker volume and backend dir
uploads/
backend/uploads/*
!backend/uploads/.gitkeep

# SSL / certificates
*.pem
*.key
*.cert
cert/
nginx/ssl/

# Editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# TypeScript
*.tsbuildinfo
