# Generate secrets with Node.js:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"   → JWT_SECRET / JWT_REFRESH_SECRET / SESSION_SECRET
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"   → ENCRYPTION_KEY / IP_HASH_SALT
